---
// 주요 기능 2x2 카드. 콘텐츠는 상단 배열로 분리해 수정 용이.
const features = [
  { icon: "📷", title: "사진 기반 사용보고", desc: "바코드를 자동 판별해 품목을 채웁니다. 수기 입력을 줄이고 오류를 막습니다." },
  { icon: "📡", title: "멀티벤더 동시 전파", desc: "한 번의 제출로 여러 벤더에게 동시에. 품목별로 담당 벤더가 자동 배정됩니다." },
  { icon: "✅", title: "확인·반려 워크플로우", desc: "벤더는 받은 보고를 확인하거나 사유와 함께 반려합니다. 명확한 피드백 창구." },
  { icon: "🔒", title: "정보 비노출 · 비동기", desc: "간호사 본인 정보는 노출되지 않습니다. 서로의 시간에 맞춰 비동기로 처리됩니다." },
];
---
<section id="features" class="border-b border-black/5 px-6 py-16 md:px-10 md:py-20">
  <p class="mb-4 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-accent">주요 기능</p>
  <h2 class="mb-8 text-2xl font-bold tracking-[-0.02em] text-ink md:text-3xl">현장에 필요한 것만, 정확하게.</h2>
  <div class="grid gap-4 md:grid-cols-2">
    {features.map((f) => (
      <div class="rounded-[11px] border border-black/8 bg-white p-6">
        <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-lg">{f.icon}</div>
        <h3 class="mb-2 text-[15px] font-semibold text-ink">{f.title}</h3>
        <p class="text-sm leading-relaxed text-muted">{f.desc}</p>
      </div>
    ))}
  </div>
</section>
