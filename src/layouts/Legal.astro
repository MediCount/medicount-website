---
import Base from "./Base.astro";
interface Props { title: string; description: string; updated: string; }
const { title, description, updated } = Astro.props;
---
<Base title={title} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <h1 class="mb-2 text-3xl font-semibold tracking-[-0.03em] text-ink">{title}</h1>
    <p class="mb-10 text-sm text-ink-subtle">시행일: {updated}</p>
    <div class="legal-body space-y-6 text-[15px] leading-7 text-ink-muted">
      <slot />
    </div>
  </article>
</Base>

<style is:global>
  .legal-body h2 { margin-top: 2rem; font-size: 1.125rem; font-weight: 600; letter-spacing: -0.01em; color: var(--color-ink); }
  .legal-body h3 { margin-top: 1.25rem; font-weight: 600; color: var(--color-ink); }
  .legal-body strong { font-weight: 600; color: var(--color-ink); }
  .legal-body a { color: var(--color-primary); }
  .legal-body ul { list-style: disc; padding-left: 1.25rem; }
  .legal-body ol { list-style: decimal; padding-left: 1.25rem; }
  .legal-body li { margin-top: 0.25rem; }
  .legal-body table { display: block; width: 100%; overflow-x: auto; border-collapse: collapse; font-size: 14px; }
  .legal-body th, .legal-body td { border: 1px solid var(--color-hairline); padding: 8px 10px; text-align: left; }
  .legal-body th { background: var(--color-surface-1); font-weight: 600; color: var(--color-ink); }
</style>
